# Database
DATABASE_URL=postgresql://dev:dev123@localhost:5432/datalink

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=datalink-uploads
MINIO_SECURE=false

# Application
MAX_FILE_SIZE_MB=500
WORKER_ENABLED=true
WORKER_INTERVAL_SECONDS=5

# Environment
ENVIRONMENT=development

CLEANUP_ENABLED=true
CLEANUP_INTERVAL_SECONDS=3600

# Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx

BILLING_SUCCESS_URL=http://localhost:3000/data-link?upgrade=success
BILLING_CANCEL_URL=http://localhost:3000/data-link?upgrade=cancelled